{
  "name": "nuxt-better-auth",
  "version": "0.1.0",
  "description": "Nuxt module for Better Auth — full lifecycle integration with auto-wired handler, SSR, session state, and typed server/client APIs",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "main": "./dist/module.cjs",
  "types": "./dist/types.d.ts",
  "files": ["dist"],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "build": "nuxt-module-build build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@nuxt/kit": "^3.16.0"
  },
  "peerDependencies": {
    "better-auth": "^1.4.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^0.8.0",
    "@nuxt/schema": "^3.16.0",
    "better-auth": "^1.4.0",
    "nuxt": "^3.16.0",
    "typescript": "^5.7.0"
  }
}
