{
  "name": "@genu/nuxt-better-auth",
  "version": "0.1.0",
  "description": "Nuxt module for Better Auth — full lifecycle integration with auto-wired handler, SSR, session state, and typed server/client APIs",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    }
  },
  "main": "./dist/module.cjs",
  "types": "./dist/types.d.ts",
  "files": ["dist"],
  "packageManager": "pnpm@10.8.1",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "nuxi dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxi prepare playground",
    "build": "nuxt-module-build build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@nuxt/kit": "3.21.2"
  },
  "peerDependencies": {
    "better-auth": "^1.4.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "0.8.4",
    "@nuxt/schema": "3.21.2",
    "better-auth": "1.5.5",
    "nuxt": "3.21.2",
    "typescript": "5.9.3"
  }
}
