{
  "name": "nuxt-better-auth-utils",
  "version": "0.1.0",
  "description": "Nuxt module for Better Auth — full lifecycle integration with auto-wired handler, SSR, session state, and typed server/client APIs",
  "license": "MIT",
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "files": ["dist"],
  "packageManager": "pnpm@10.8.1",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm dev:prepare && nuxi dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@nuxt/kit": "4.3.1"
  },
  "peerDependencies": {
    "better-auth": "^1.4.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/schema": "4.3.1",
    "better-auth": "1.5.5",
    "nuxt": "4.3.1",
    "typescript": "5.9.3"
  }
}
