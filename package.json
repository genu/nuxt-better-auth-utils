{
  "name": "nuxt-better-auth-utils",
  "version": "0.1.27",
  "description": "Nuxt module for Better Auth — full lifecycle integration with auto-wired handler, SSR, session state, and typed server/client APIs",
  "repository": {
    "type": "git",
    "url": "https://github.com/genu/nuxt-better-auth-utils"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.mts"
      ],
      "types": [
        "./dist/types.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./types": {
      "types": "./dist/types.d.mts",
      "import": "./dist/types.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.33.2",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "pnpm dev:prepare && nuxi dev playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@nuxt/kit": "4.4.2",
    "defu": "6.1.7"
  },
  "peerDependencies": {
    "better-auth": "^1.4.0"
  },
  "devDependencies": {
    "@nuxt/module-builder": "1.0.2",
    "@nuxt/schema": "4.4.2",
    "@nuxt/test-utils": "4.0.2",
    "better-auth": "1.6.8",
    "happy-dom": "20.9.0",
    "nuxt": "4.4.2",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "vue-tsc": "3.2.7"
  }
}
