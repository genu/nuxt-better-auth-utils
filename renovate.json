{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":dependencyDashboard",
        ":semanticCommitTypeAll(chore)",
        ":label(dependencies)",
        ":disablePeerDependencies"
    ],
    "packageRules": [
        {
            "description": "Group Nuxt ecosystem packages",
            "groupName": "nuxt",
            "matchPackageNames": ["/^@nuxt//", "/^nuxt$/", "/^nuxi$/"]
        },
        {
            "description": "Group Better Auth packages",
            "groupName": "better-auth",
            "matchPackageNames": ["/^better-auth/"]
        },
        {
            "description": "Group linting tools",
            "groupName": "linting",
            "matchPackageNames": ["/^eslint/", "/^prettier/"]
        },
        {
            "description": "Automerge minor/patch devDependencies",
            "matchDepTypes": ["devDependencies"],
            "matchUpdateTypes": ["minor", "patch"],
            "automerge": true
        }
    ]
}
